# Copy to .env and fill in for local development.
# Every value below has a working default for a zero-config demo —
# you only need to set GEMINI_API_KEY to unlock live AI-generated
# Copilot answers instead of the retrieval-only fallback.

ENVIRONMENT=development

# For a quick demo without provisioning Postgres, use SQLite instead:
#   DATABASE_URL=sqlite+aiosqlite:///./dev.db
# (also run: pip install aiosqlite)
DATABASE_URL=postgresql+asyncpg://industrialbrain:industrialbrain@localhost:5432/industrialbrain

# Leave as :memory: for a zero-config demo (resets on restart), or
# point at a real Qdrant instance (see docker-compose.yml) to persist.
QDRANT_URL=:memory:

# Optional — Knowledge Graph works without this (uses a Postgres-derived
# fallback graph). Set these if you're running the Neo4j container.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# Optional — Copilot gives real retrieved evidence either way; this
# unlocks Gemini-generated synthesis on top of that evidence.
GEMINI_API_KEY=
